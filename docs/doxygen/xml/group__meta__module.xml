<sect1 id="group__meta__module_1meta_overview">
<title>Overview</title>
<para>The Meta module handles metadata associated with samples, events, and analysis configurations.</para>
</sect1>
<sect1 id="group__meta__module_1meta_information">
<title>Stored Information</title>
<para>Metadata includes:</para>
<para><itemizedlist>
<listitem><para>Sample identification</para>
</listitem><listitem><para>Cross-section weights</para>
</listitem><listitem><para>Processing history</para>
</listitem><listitem><para>Configuration snapshots</para>
</listitem></itemizedlist>
</para>
<para><simplesect kind="see"><para><ref refid="classmeta" kindref="compound">meta</ref> </para>
</simplesect>
</para>
