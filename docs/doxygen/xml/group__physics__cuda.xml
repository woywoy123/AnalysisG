<sect1 id="group__physics__cuda_1physics_example">
<title>Example</title>
<para><programlisting filename=".cpp"><codeline><highlight class="preprocessor">#include<sp/>&lt;<ref refid="physics_8cuh" kindref="compound">physics/physics.cuh</ref>&gt;</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>Create<sp/>momentum<sp/>tensor<sp/>[N,<sp/>4]<sp/>=<sp/>(px,<sp/>py,<sp/>pz,<sp/>E)</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">torch::Tensor<sp/><ref refid="enums_8h_1a666fa98df084d96fc481369704153b28a04130da60e65c7800006cd7886515b56" kindref="member">pmc</ref><sp/>=<sp/>torch::randn({100,<sp/>4}).cuda();</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>Calculate<sp/>invariant<sp/>mass</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">torch::Tensor<sp/><ref refid="enums_8h_1a666fa98df084d96fc481369704153b28ad90ccffa01275a7a7795fb6d1274e75f" kindref="member">mass</ref><sp/>=<sp/><ref refid="namespacephysics___1a64e8e583c57246f52851c0bff4137ebc" kindref="member">physics_::M</ref>(&amp;<ref refid="enums_8h_1a666fa98df084d96fc481369704153b28a04130da60e65c7800006cd7886515b56" kindref="member">pmc</ref>);</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>Calculate<sp/>beta<sp/>factor</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">torch::Tensor<sp/>beta<sp/>=<sp/><ref refid="namespacephysics___1a3123f743b9c22850e7346d5f56a4441b" kindref="member">physics_::Beta</ref>(&amp;<ref refid="enums_8h_1a666fa98df084d96fc481369704153b28a04130da60e65c7800006cd7886515b56" kindref="member">pmc</ref>);</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>Calculate<sp/>DeltaR<sp/>between<sp/>particle<sp/>pairs</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">torch::Tensor<sp/>pmu1<sp/>=<sp/>torch::randn({50,<sp/>4}).cuda();</highlight></codeline>
<codeline><highlight class="normal">torch::Tensor<sp/>pmu2<sp/>=<sp/>torch::randn({50,<sp/>4}).cuda();</highlight></codeline>
<codeline><highlight class="normal">torch::Tensor<sp/>dR<sp/>=<sp/><ref refid="namespacephysics___1a5f66fa5ca30082509e1284fbcb4b25be" kindref="member">physics_::DeltaR</ref>(&amp;pmu1,<sp/>&amp;pmu2);</highlight></codeline>
</programlisting> </para>
</sect1>
