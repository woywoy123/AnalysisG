<codeline><highlight class="normal">params.<ref refid="structoptimizer__params__t_1a5bdbcab5994d44e129e0b243b6bb0361" kindref="member">betas</ref><sp/>=<sp/>{0.9,<sp/>0.999};</highlight></codeline>
<codeline><highlight class="normal">params.<ref refid="structoptimizer__params__t_1ab9b13705461cc1d83ba166bb33151039" kindref="member">amsgrad</ref><sp/>=<sp/></highlight><highlight class="keyword">true</highlight><highlight class="normal">;</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
