<sect1 id="python_complete_example_1complete_particles">
<title>Define Particles</title>
<para><programlisting filename=".py"><codeline><highlight class="keyword">class<sp/></highlight><highlight class="normal">Jet(ParticleTemplate):</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight><highlight class="keyword">def<sp/></highlight><highlight class="normal">__init__(self):</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>ParticleTemplate.__init__(self)</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.Leaves<sp/>=<sp/>[</highlight><highlight class="stringliteral">&quot;pt&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;eta&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;phi&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;e&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;btag&quot;</highlight><highlight class="normal">]</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight><highlight class="preprocessor">@property</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight><highlight class="keyword">def<sp/></highlight><highlight class="normal">is_bjet(self):</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/></highlight><highlight class="keywordflow">return</highlight><highlight class="normal"><sp/>self.btag<sp/>&gt;<sp/>0.7</highlight></codeline>
</programlisting></para>
</sect1>
<sect1 id="python_complete_example_1complete_event">
<title>Define Event</title>
<para><programlisting filename=".py"><codeline><highlight class="keyword">class<sp/></highlight><highlight class="normal">TTbarEvent(EventTemplate):</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight><highlight class="keyword">def<sp/></highlight><highlight class="normal">__init__(self):</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>EventTemplate.__init__(self)</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.name<sp/>=<sp/></highlight><highlight class="stringliteral">&quot;ttbar&quot;</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.Trees<sp/>=<sp/>[</highlight><highlight class="stringliteral">&quot;nominal&quot;</highlight><highlight class="normal">]</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.Branches<sp/>=<sp/>[</highlight><highlight class="stringliteral">&quot;jet_&quot;</highlight><highlight class="normal">]</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.Leaves<sp/>=<sp/>[</highlight><highlight class="stringliteral">&quot;met_et&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;met_phi&quot;</highlight><highlight class="normal">]</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.Objects<sp/>=<sp/>{</highlight><highlight class="stringliteral">&quot;Jets&quot;</highlight><highlight class="normal">:<sp/>Jet}</highlight></codeline>
</programlisting></para>
</sect1>
<sect1 id="python_complete_example_1complete_graph">
<title>Define Graph</title>
<para><programlisting filename=".py"><codeline><highlight class="keyword">class<sp/></highlight><highlight class="normal">JetGraph(GraphTemplate):</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight><highlight class="keyword">def<sp/></highlight><highlight class="normal">__init__(self):</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>GraphTemplate.__init__(self)</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.name<sp/>=<sp/></highlight><highlight class="stringliteral">&quot;jet_graph&quot;</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight><highlight class="keyword">def<sp/></highlight><highlight class="normal">CompileEvent(self,<sp/>event):</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.DefineNodes(event.Jets)</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.AddNodeFeature(</highlight><highlight class="stringliteral">&quot;pt&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="keyword">lambda</highlight><highlight class="normal"><sp/>j:<sp/>j.pt<sp/>/<sp/>1000)</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.AddNodeFeature(</highlight><highlight class="stringliteral">&quot;eta&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="keyword">lambda</highlight><highlight class="normal"><sp/>j:<sp/>j.eta)</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.AddNodeFeature(</highlight><highlight class="stringliteral">&quot;phi&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="keyword">lambda</highlight><highlight class="normal"><sp/>j:<sp/>j.phi)</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.AddNodeTruth(</highlight><highlight class="stringliteral">&quot;is_b&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="keyword">lambda</highlight><highlight class="normal"><sp/>j:<sp/>int(j.is_bjet))</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight><highlight class="keyword">def<sp/></highlight><highlight class="normal">PreSelection(self,<sp/>event):</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/></highlight><highlight class="keywordflow">return</highlight><highlight class="normal"><sp/>len(event.Jets)<sp/>&gt;=<sp/>4</highlight></codeline>
</programlisting></para>
</sect1>
<sect1 id="python_complete_example_1complete_model">
<title>Define Model</title>
<para><programlisting filename=".py"><codeline><highlight class="keyword">class<sp/></highlight><highlight class="normal">JetTagger(ModelTemplate):</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight><highlight class="keyword">def<sp/></highlight><highlight class="normal">__init__(self):</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>ModelTemplate.__init__(self)</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.fc<sp/>=<sp/>nn.Sequential(</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>nn.Linear(3,<sp/>64),</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>nn.ReLU(),</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>nn.Linear(64,<sp/>32),</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>nn.ReLU(),</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>nn.Linear(32,<sp/>1),</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>nn.Sigmoid()</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>)</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.i_node<sp/>=<sp/>[</highlight><highlight class="stringliteral">&quot;pt&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;eta&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;phi&quot;</highlight><highlight class="normal">]</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>self.o_node<sp/>=<sp/>{</highlight><highlight class="stringliteral">&quot;pred&quot;</highlight><highlight class="normal">:<sp/></highlight><highlight class="stringliteral">&quot;is_b&quot;</highlight><highlight class="normal">}</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight><highlight class="keyword">def<sp/></highlight><highlight class="normal">forward(self,<sp/>data):</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>x<sp/>=<sp/>data.node_features</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/></highlight><highlight class="keywordflow">return</highlight><highlight class="normal"><sp/>{</highlight><highlight class="stringliteral">&quot;pred&quot;</highlight><highlight class="normal">:<sp/>self.fc(x)}</highlight></codeline>
</programlisting></para>
</sect1>
<sect1 id="python_complete_example_1complete_run">
<title>Run Analysis</title>
<para><programlisting filename=".py"><codeline><highlight class="comment">#<sp/>Create<sp/>analysis</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana<sp/>=<sp/>Analysis()</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">#<sp/>Configure</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana.OutputPath<sp/>=<sp/></highlight><highlight class="stringliteral">&quot;results/&quot;</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana.Epochs<sp/>=<sp/>50</highlight></codeline>
<codeline><highlight class="normal">ana.kFolds<sp/>=<sp/>5</highlight></codeline>
<codeline><highlight class="normal">ana.BatchSize<sp/>=<sp/>64</highlight></codeline>
<codeline><highlight class="normal">ana.Threads<sp/>=<sp/>8</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">#<sp/>Add<sp/>data</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana.AddSamples(</highlight><highlight class="stringliteral">&quot;/data/ttbar/&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;ttbar&quot;</highlight><highlight class="normal">)</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">#<sp/>Add<sp/>templates</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana.AddEvent(TTbarEvent(),<sp/></highlight><highlight class="stringliteral">&quot;ttbar&quot;</highlight><highlight class="normal">)</highlight></codeline>
<codeline><highlight class="normal">ana.AddGraph(JetGraph(),<sp/></highlight><highlight class="stringliteral">&quot;ttbar&quot;</highlight><highlight class="normal">)</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">#<sp/>Configure<sp/>optimizer</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">opt<sp/>=<sp/>OptimizerConfig()</highlight></codeline>
<codeline><highlight class="normal">opt.optimizer<sp/>=<sp/></highlight><highlight class="stringliteral">&quot;Adam&quot;</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">opt.lr<sp/>=<sp/>0.001</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">#<sp/>Add<sp/>model</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana.AddModel(JetTagger(),<sp/>opt,<sp/></highlight><highlight class="stringliteral">&quot;btagger&quot;</highlight><highlight class="normal">)</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">#<sp/>Run</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana.Start()</highlight></codeline>
</programlisting> </para>
</sect1>
