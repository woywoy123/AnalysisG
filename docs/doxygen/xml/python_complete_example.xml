<codeline><highlight class="normal"></highlight><highlight class="keyword">from</highlight><highlight class="normal"><sp/>AnalysisG.core<sp/></highlight><highlight class="keyword">import</highlight><highlight class="normal"><sp/>GraphTemplate</highlight></codeline>
