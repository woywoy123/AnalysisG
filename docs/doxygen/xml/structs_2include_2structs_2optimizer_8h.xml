    <innerclass refid="structoptimizer__params__t" prot="public">optimizer_params_t</innerclass>
    <briefdescription>
<para>Defines the <ref refid="structoptimizer__params__t" kindref="compound">optimizer_params_t</ref> structure for configuring model optimizers. </para>
    </briefdescription>
    <detaileddescription>
