<doxygen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="compound.xsd" version="1.9.8" xml:lang="en-US">
  <compounddef id="group__particle__module" kind="group">
    <compoundname>particle_module</compoundname>
    <title>Particle Module</title>
    <briefdescription>
<para>Particle representations and properties. </para>
    </briefdescription>
    <detaileddescription>
<sect1 id="group__particle__module_1particle_overview">
<title>Overview</title>
<para>The Particle module provides the <ref refid="classparticle__template" kindref="compound">particle_template</ref> class for representing physics particles in the analysis.</para>
</sect1>
<sect1 id="group__particle__module_1particle_properties">
<title>Properties</title>
<para>Typical particle properties include:</para>
<para><itemizedlist>
<listitem><para>Four-momentum (pT, eta, phi, E/m)</para>
</listitem><listitem><para>Identification (PDG ID, truth matching)</para>
</listitem><listitem><para>Quality flags</para>
</listitem><listitem><para>Isolation variables</para>
</listitem></itemizedlist>
</para>
</sect1>
<sect1 id="group__particle__module_1particle_operations">
<title>Operations</title>
<para>Particles support operations like:</para>
<para><itemizedlist>
<listitem><para>Four-vector addition</para>
</listitem><listitem><para>DeltaR calculations</para>
</listitem><listitem><para>Invariant mass computation</para>
</listitem></itemizedlist>
</para>
<para><simplesect kind="see"><para><ref refid="classparticle__template" kindref="compound">particle_template</ref> </para>
</simplesect>
</para>
</sect1>
    </detaileddescription>
  </compounddef>
</doxygen>
