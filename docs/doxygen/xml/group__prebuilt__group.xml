    <detaileddescription>
<para>AnalysisG includes several pre-built templates for common use cases in high-energy physics analysis.</para>
<sect1 id="group__prebuilt__group_1prebuilt_events">
<title>Pre-built Events</title>
<para>Located in <computeroutput>src/AnalysisG/events/</computeroutput>:</para>
<para><table rows="5" cols="2"><row>
<entry thead="yes"><para>Event   </para>
</entry><entry thead="yes"><para>Description    </para>
</entry></row>
<row>
<entry thead="no"><para><computeroutput><ref refid="classbsm__4tops" kindref="compound">bsm_4tops</ref></computeroutput>   </para>
</entry><entry thead="no"><para>BSM 4-top analysis events    </para>
</entry></row>
<row>
<entry thead="no"><para><computeroutput><ref refid="classexp__mc20" kindref="compound">exp_mc20</ref></computeroutput>   </para>
</entry><entry thead="no"><para>Experimental MC20 format    </para>
</entry></row>
<row>
<entry thead="no"><para><computeroutput>gnn</computeroutput>   </para>
</entry><entry thead="no"><para>GNN-specific event format    </para>
</entry></row>
<row>
<entry thead="no"><para><computeroutput><ref refid="classssml__mc20" kindref="compound">ssml_mc20</ref></computeroutput>   </para>
</entry><entry thead="no"><para>SSML MC20 format   </para>
</entry></row>
</table>
</para>
</sect1>
