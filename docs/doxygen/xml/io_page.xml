<sect1 id="io_page_1io_intro">
<title>Introduction</title>
<para>The <ref refid="classio" kindref="compound">io</ref> class handles all input/output operations in AnalysisG, supporting both ROOT and HDF5 file formats.</para>
</sect1>
<sect1 id="io_page_1io_formats">
<title>Supported Formats</title>
<para><table rows="3" cols="4"><row>
<entry thead="yes"><para>Format   </para>
</entry><entry thead="yes"><para>Read   </para>
</entry><entry thead="yes"><para>Write   </para>
</entry><entry thead="yes"><para>Use Case    </para>
</entry></row>
<row>
<entry thead="no"><para>ROOT   </para>
</entry><entry thead="no"><para>✓   </para>
</entry><entry thead="no"><para>✓   </para>
</entry><entry thead="no"><para>Physics data (ntuples)    </para>
</entry></row>
<row>
<entry thead="no"><para>HDF5   </para>
</entry><entry thead="no"><para>✓   </para>
</entry><entry thead="no"><para>✓   </para>
</entry><entry thead="no"><para><ref refid="classGraph" kindref="compound">Graph</ref> data, tensors   </para>
</entry></row>
</table>
</para>
</sect1>
<sect1 id="io_page_1io_root">
<title>ROOT Operations</title>
<sect2 id="io_page_1io_root_read">
<title>Reading ROOT Files</title>
<para><programlisting filename=".cpp"><codeline><highlight class="normal"><ref refid="classio" kindref="compound">io</ref><sp/>reader;</highlight></codeline>
<codeline><highlight class="normal">reader.<ref refid="classio_1a793e5c59d9bf747540db2570e9e40d10" kindref="member">trees</ref><sp/>=<sp/>{</highlight><highlight class="stringliteral">&quot;nominal&quot;</highlight><highlight class="normal">};</highlight></codeline>
<codeline><highlight class="normal">reader.<ref refid="classio_1a21d6fc9f9b2e516e8b53900c507966c3" kindref="member">branches</ref><sp/>=<sp/>{</highlight><highlight class="stringliteral">&quot;jet_&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;el_&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;mu_&quot;</highlight><highlight class="normal">};</highlight></codeline>
<codeline><highlight class="normal">reader.<ref refid="classio_1a77890c20f1b193b44925763aca5b7aca" kindref="member">leaves</ref><sp/>=<sp/>{</highlight><highlight class="stringliteral">&quot;met_et&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;met_phi&quot;</highlight><highlight class="normal">};</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>Open<sp/>and<sp/>read</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">reader.<ref refid="classio_1a228b6ce6f26848a9adfc0ccf3619a53e" kindref="member">start</ref>(</highlight><highlight class="stringliteral">&quot;data.root&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;read&quot;</highlight><highlight class="normal">);</highlight></codeline>
<codeline><highlight class="normal">reader.<ref refid="classio_1a65c36380ef79524e8235f792abe9625c" kindref="member">root_begin</ref>();</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>Access<sp/>data</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">auto</highlight><highlight class="normal">*<sp/>data<sp/>=<sp/>reader.<ref refid="classio_1ae346e23a45d73c24f844827495912941" kindref="member">get_data</ref>();</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>Process<sp/>entries...</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">reader.<ref refid="classio_1a1c994985d2405202c19fb391cc43a5de" kindref="member">root_end</ref>();</highlight></codeline>
<codeline><highlight class="normal">reader.<ref refid="classio_1a65ca69ec5f12d0f3a463396bcff84d77" kindref="member">end</ref>();</highlight></codeline>
</programlisting></para>
</sect2>
</sect1>
<sect1 id="io_page_1io_hdf5">
<title>HDF5 Operations</title>
<sect2 id="io_page_1io_hdf5_write">
<title>Writing HDF5 Data</title>
<para><programlisting filename=".cpp"><codeline><highlight class="normal"><ref refid="classio" kindref="compound">io</ref><sp/><ref refid="structwriter" kindref="compound">writer</ref>;</highlight></codeline>
<codeline><highlight class="normal"><ref refid="structwriter" kindref="compound">writer</ref>.start(</highlight><highlight class="stringliteral">&quot;output.h5&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;write&quot;</highlight><highlight class="normal">);</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">std::vector&lt;double&gt;<sp/>values<sp/>=<sp/>{...};</highlight></codeline>
<codeline><highlight class="normal"><ref refid="structwriter" kindref="compound">writer</ref>.<ref refid="structwriter_1a5b6e08a06c4e563a35520694615f78a3" kindref="member">write</ref>(&amp;values,<sp/></highlight><highlight class="stringliteral">&quot;dataset_name&quot;</highlight><highlight class="normal">);</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="structwriter" kindref="compound">writer</ref>.end();</highlight></codeline>
</programlisting></para>
</sect2>
<sect2 id="io_page_1io_hdf5_read">
<title>Reading HDF5 Data</title>
<para><programlisting filename=".cpp"><codeline><highlight class="normal"><ref refid="classio" kindref="compound">io</ref><sp/>reader;</highlight></codeline>
<codeline><highlight class="normal">reader.<ref refid="classio_1a228b6ce6f26848a9adfc0ccf3619a53e" kindref="member">start</ref>(</highlight><highlight class="stringliteral">&quot;input.h5&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;read&quot;</highlight><highlight class="normal">);</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">std::vector&lt;double&gt;<sp/>values;</highlight></codeline>
<codeline><highlight class="normal">reader.<ref refid="classio_1a2a0214e493a7a2ef5e9507c0e6aa4e70" kindref="member">read</ref>(&amp;values,<sp/></highlight><highlight class="stringliteral">&quot;dataset_name&quot;</highlight><highlight class="normal">);</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">reader.<ref refid="classio_1a65ca69ec5f12d0f3a463396bcff84d77" kindref="member">end</ref>();</highlight></codeline>
</programlisting></para>
</sect2>
</sect1>
