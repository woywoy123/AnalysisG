<doxygen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="compound.xsd" version="1.9.8" xml:lang="en-US">
  <compounddef id="group__selection__module" kind="group">
    <compoundname>selection_module</compoundname>
    <title>Selection Module</title>
    <briefdescription>
<para>Event selection criteria. </para>
    </briefdescription>
    <detaileddescription>
<sect1 id="group__selection__module_1selection_overview">
<title>Overview</title>
<para>The Selection module provides the <ref refid="classselection__template" kindref="compound">selection_template</ref> class for implementing event selection criteria.</para>
</sect1>
<sect1 id="group__selection__module_1selection_usage_mod">
<title>Usage</title>
<para>To create a custom selection:</para>
<para><orderedlist>
<listitem><para>Subclass <ref refid="classselection__template" kindref="compound">selection_template</ref></para>
</listitem><listitem><para>Override the selection method</para>
</listitem><listitem><para>Return true for events that pass the selection</para>
</listitem></orderedlist>
</para>
</sect1>
<sect1 id="group__selection__module_1selection_chaining_mod">
<title>Selection Chaining</title>
<para>Multiple selections can be combined:</para>
<para><itemizedlist>
<listitem><para>Sequential (AND logic)</para>
</listitem><listitem><para>Named selections for cutflow analysis</para>
</listitem></itemizedlist>
</para>
<para><simplesect kind="see"><para><ref refid="classselection__template" kindref="compound">selection_template</ref> </para>
</simplesect>
</para>
</sect1>
    </detaileddescription>
  </compounddef>
</doxygen>
