<sect1 id="python_analysis_page_1python_import">
<title>Importing</title>
<para><programlisting filename=".py"><codeline><highlight class="keyword">from</highlight><highlight class="normal"><sp/>AnalysisG.core<sp/></highlight><highlight class="keyword">import</highlight><highlight class="normal"><sp/>Analysis</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">from</highlight><highlight class="normal"><sp/>AnalysisG.core<sp/></highlight><highlight class="keyword">import</highlight><highlight class="normal"><sp/>EventTemplate,<sp/>GraphTemplate</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">from</highlight><highlight class="normal"><sp/>AnalysisG.core<sp/></highlight><highlight class="keyword">import</highlight><highlight class="normal"><sp/>ModelTemplate,<sp/>SelectionTemplate</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">from</highlight><highlight class="normal"><sp/>AnalysisG.core<sp/></highlight><highlight class="keyword">import</highlight><highlight class="normal"><sp/>OptimizerConfig</highlight></codeline>
</programlisting></para>
</sect1>
<sect1 id="python_analysis_page_1python_basic">
<title>Basic Usage</title>
<para><programlisting filename=".py"><codeline><highlight class="keyword">from</highlight><highlight class="normal"><sp/>AnalysisG.core<sp/></highlight><highlight class="keyword">import</highlight><highlight class="normal"><sp/>Analysis</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">#<sp/>Create<sp/>analysis<sp/>instance</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana<sp/>=<sp/>Analysis()</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">#<sp/>Configure<sp/>settings</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana.OutputPath<sp/>=<sp/></highlight><highlight class="stringliteral">&quot;results/&quot;</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana.Threads<sp/>=<sp/>8</highlight></codeline>
<codeline><highlight class="normal">ana.Epochs<sp/>=<sp/>100</highlight></codeline>
<codeline><highlight class="normal">ana.kFolds<sp/>=<sp/>5</highlight></codeline>
<codeline><highlight class="normal">ana.BatchSize<sp/>=<sp/>64</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">#<sp/>Add<sp/>data<sp/>samples</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana.AddSamples(</highlight><highlight class="stringliteral">&quot;/path/to/data/&quot;</highlight><highlight class="normal">,<sp/></highlight><highlight class="stringliteral">&quot;sample_label&quot;</highlight><highlight class="normal">)</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">#<sp/>Add<sp/>templates</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana.AddEvent(MyEvent(),<sp/></highlight><highlight class="stringliteral">&quot;sample_label&quot;</highlight><highlight class="normal">)</highlight></codeline>
<codeline><highlight class="normal">ana.AddGraph(MyGraph(),<sp/></highlight><highlight class="stringliteral">&quot;sample_label&quot;</highlight><highlight class="normal">)</highlight></codeline>
<codeline><highlight class="normal">ana.AddSelection(MySelection())</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">#<sp/>Add<sp/>model<sp/>for<sp/>training</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">opt<sp/>=<sp/>OptimizerConfig()</highlight></codeline>
<codeline><highlight class="normal">opt.lr<sp/>=<sp/>0.001</highlight></codeline>
<codeline><highlight class="normal">ana.AddModel(MyModel(),<sp/>opt,<sp/></highlight><highlight class="stringliteral">&quot;training_run&quot;</highlight><highlight class="normal">)</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">#<sp/>Start<sp/>analysis</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">ana.Start()</highlight></codeline>
</programlisting></para>
</sect1>
